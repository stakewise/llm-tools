{
  "id": "stakewise-llm-tools",
  "name": "StakeWise Staking",
  "description": "Starts the local StakeWise API server and runs scripts to retrieve protocol data",
  "entry": "./index.ts",
  "skills": [ "./skills" ],
  "configSchema": {
    "type": "object",
    "properties": {
      "port": {
        "type": "number",
        "default": 5165
      },
      "host": {
        "type": "string",
        "default": "127.0.0.1"
      }
    },
    "additionalProperties": false
  }
}
