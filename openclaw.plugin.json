{
  "id": "stakewise-llm-tools",
  "name": "Stakewise Staking",
  "description": "Starts a local Stakewise API server and ships a skill for balance lookup",
  "entry": "./index.ts",
  "skills": [ "./skills" ],
  "configSchema": {
    "type": "object",
    "properties": {
      "port": {
        "type": "number",
        "default": 5165
      },
      "host": {
        "type": "string",
        "default": "127.0.0.1"
      }
    },
    "additionalProperties": false
  }
}
