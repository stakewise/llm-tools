{
  "name": "stakewise-staking",
  "version": "1.1.0",
  "description": "Ethereum staking tools with StakeWise protocol",
  "type": "module",
  "main": "index.ts",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "openclaw",
    "openclaw-plugin",
    "stakewise",
    "staking",
    "ethereum"
  ],
  "openclaw": {
    "compat": {
      "pluginApi": ">=2026.4.2"
    },
    "build": {
      "openclawVersion": "2026.4.6"
    },
    "extensions": [
      "./index.ts"
    ],
    "skills": [
      "./skills"
    ]
  },
  "peerDependencies": {
    "openclaw": "*"
  },
  "devDependencies": {
    "@types/node": "25.0.0",
    "typescript": "6.0.2",
    "vitest": "3.0.0"
  },
  "dependencies": {
    "@stakewise/v3-sdk": "4.2.3",
    "ethers": "^6.16.0"
  }
}
